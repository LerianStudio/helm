{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "namespaceOverride": {
      "type": "string"
    },
    "global": {
      "type": "object",
      "additionalProperties": true
    },
    "underwriter": {
      "type": "object",
      "properties": {
        "configmap": {
          "type": "object"
        },
        "secrets": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "valkey": {
      "type": "object",
      "additionalProperties": true
    },
    "postgresql": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "fullnameOverride",
    "global",
    "nameOverride",
    "namespaceOverride",
    "postgresql",
    "underwriter",
    "valkey"
  ]
}
