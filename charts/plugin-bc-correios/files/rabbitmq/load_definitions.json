      "durable": true,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "bc-correios.audit",
      "vhost": "/",
      "destination": "bc-correios.audit.events",
      "destination_type": "queue",
      "routing_key": "audit.event.#"
