{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "namespaceOverride": {
      "type": "string"
    },
    "global": {
      "type": "object",
      "additionalProperties": true
    },
    "ledger": {
      "type": "object",
      "properties": {
        "configmap": {
          "type": "object"
        },
        "secrets": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "crm": {
      "type": "object",
      "properties": {
        "configmap": {
          "type": "object"
        },
        "secrets": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "grafana": {
      "type": "object",
      "additionalProperties": true
    },
    "valkey": {
      "type": "object",
      "additionalProperties": true
    },
    "postgresql": {
      "type": "object",
      "additionalProperties": true
    },
    "mongodb": {
      "type": "object",
      "additionalProperties": true
    },
    "rabbitmq": {
      "type": "object",
      "additionalProperties": true
    },
    "otel-collector-lerian": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "When true, inject OTEL env vars (HOST_IP, POD_IP, OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_RESOURCE_ATTRIBUTES) into midaz ledger and crm deployments. The endpoint is fixed at $(HOST_IP):4317 — apps require an OTEL collector listening on the node. To use a different endpoint, leave enabled=false and set OTEL_EXPORTER_OTLP_ENDPOINT directly in the application configmap (ledger.configmap / crm.configmap)."
        }
      },
      "required": ["enabled"]
    }
  }
}
